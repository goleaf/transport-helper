APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

SUPPLY_EMAIL_SENDER=log
SUPPLY_EMAIL_FROM=
SUPPLY_EMAIL_PROVIDER=manual
SUPPLY_EMAIL_ANALYZER=rule_based
SUPPLY_EMAIL_AUTO_ANALYZE=false
SUPPLY_FORM_AUTOFILL_EXTRACTOR=rule_based
SUPPLY_SEASONALITY_MIN_FACTOR=0.50
SUPPLY_SEASONALITY_MAX_FACTOR=2.00
SUPPLY_SEASONALITY_MIN_HISTORY_MONTHS=12
SUPPLY_OUTLIER_MULTIPLIER=3.0
SUPPLY_ALLOW_SCENARIO_TO_PROPOSAL=false
SUPPLY_PROCUREMENT_CONTROLS_ENABLED=true
SUPPLY_PROCUREMENT_DEFAULT_ENFORCEMENT=advisory
SUPPLY_PROCUREMENT_ALLOW_SELF_APPROVAL=false
SUPPLY_PROCUREMENT_DEFAULT_CURRENCY=EUR
SUPPLY_PROCUREMENT_BLOCK_MISSING_PRICE=true
SUPPLY_MASTER_DATA_NAME_SIMILARITY_THRESHOLD=0.85
SUPPLY_LOGISTICS_EXPECTED_SOON_DAYS=3
SUPPLY_MISSING_CONFIRMATION_AFTER_DAYS=5
SUPPLY_READY_DATE_MISSING_AFTER_CONFIRMATION_DAYS=2
SUPPLY_LOGISTICS_AUTO_DELAY_STATUS=true
SUPPLY_EXTERNAL_AI_ALLOWED=false
SUPPLY_BACKUP_MARKER_PATH=
SUPPLY_BACKUP_MAX_AGE_HOURS=48
SUPPLY_PRODUCTION_READINESS_STRICT=false
SUPPLY_LOCAL_MODE=true
SUPPLY_REAL_INTEGRATION_CALLS_ENABLED=false
SUPPLY_ALLOW_AUTO_APPROVE_LOCAL_INTEGRATIONS=true
SUPPLY_GMAIL_ENABLED=false
SUPPLY_MICROSOFT_GRAPH_ENABLED=false
SUPPLY_IMAP_ENABLED=false
SUPPLY_SMTP_ENABLED=false
SUPPLY_MANUFACTURER_EXCEL_FORMS_ENABLED=true
SUPPLY_MANUFACTURER_PDF_FORMS_ENABLED=false
SUPPLY_MANUFACTURER_FORM_MAX_UPLOAD_SIZE_KB=10240
SUPPLY_GOOGLE_SHEETS_ENABLED=false
SUPPLY_EXTERNAL_AI_ENABLED=false
SUPPLY_PILOT_STORAGE_PATH=pilot
SUPPLY_PILOT_ALLOW_REAL_EMAIL_SEND=false
SUPPLY_PILOT_ALLOW_REAL_EXTERNAL_CALLS=false
SUPPLY_PILOT_ALLOW_EXTERNAL_AI=false
SUPPLY_PILOT_MAX_UPLOAD_SIZE_KB=10240
SUPPLY_INCIDENTS_ENABLED=true
SUPPLY_INCIDENT_AUTO_DETECTION_ENABLED=true
SUPPLY_INCIDENT_SLA_MONITOR_ENABLED=true
SUPPLY_INCIDENT_AI_REVIEW_OVERDUE_HOURS=24
SUPPLY_INCIDENT_FORM_REVIEW_OVERDUE_HOURS=24
SUPPLY_INCIDENT_PROPOSAL_REVIEW_OVERDUE_HOURS=48
SUPPLY_INCIDENT_EMAIL_APPROVAL_OVERDUE_HOURS=24
SUPPLY_INCIDENT_UNKNOWN_SKU_OVERDUE_HOURS=24

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
